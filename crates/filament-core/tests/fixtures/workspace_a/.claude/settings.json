{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Skill", "Bash(git status)", "Agent(debugger)"],
    "deny": ["Bash(rm -rf*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "echo about to run bash" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "~/.claude/cleanup.sh" }]
      }
    ]
  },
  "env": { "FILAMENT_ENV": "test" }
}
